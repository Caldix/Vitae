ar(--text2); } .settings-action { color: var(--text2); font-size: 0.85rem; } /* ─── TOGGLE ─────────────────────────────────────── */ .toggle { width: 44px; height: 24px; border-radius: 12px; background: var(--surface3); position: relative; cursor: pointer; transition: background var(--transition); flex-shrink: 0; } .toggle.on { background: var(--accent); } .toggle::after { content: ''; position: absolute; width: 18px; height: 18px; border-radius: 50%; background: white; top: 3px; left: 3px; transition: transform var(--transition); } .toggle.on::after { transform: translateX(20px); } /* ─── ONBOARDING ─────────────────────────────────── */ .onboarding { display: none; position: fixed; inset: 0; background: var(--bg); z-index: 500; overflow-y: auto; } .onboarding.show { display: block; } .ob-header { text-align: center; padding: 48px 24px 32px; } .ob-emoji { font-size: 3rem; margin-bottom: 16px; } .ob-title { font-family: 'Fraunces', serif; font-size: 1.8rem; font-weight: 600; color: var(--accent); margin-bottom: 8px; } .ob-sub { font-size: 0.9rem; color: var(--text2); line-height: 1.5; } .ob-steps { padding: 0 20px 40px; } .ob-step { display: none; } .ob-step.active { display: block; } .ob-step-title { font-family: 'Fraunces', serif; font-size: 1.2rem; margin-bottom: 6px; } .ob-step-sub { font-size: 0.82rem; color: var(--text2); margin-bottom: 20px; line-height: 1.5; } .ob-progress { display: flex; gap: 6px; justify-content: center; margin: 0 24px 24px; } .ob-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--surface3); transition: all 0.2s; } .ob-dot.done { background: var(--accent); } .ob-dot.active { background: var(--accent); width: 20px; border-radius: 3px; } /* ─── MISC ───────────────────────────────────────── */ .loading { display: flex; align-items: center; justify-content: center; gap: 8px; padding: 20px; color: var(--text2); font-size: 0.85rem; } .spinner { width: 20px; height: 20px; border: 2px solid var(--surface3); border-top-color: var(--accent); border-radius: 50%; animation: spin 0.8s linear infinite; } @keyframes spin { to { transform: rotate(360deg); } } .empty-state { text-align: center; padding: 32px 20px; color: var(--text2); } .empty-icon { font-size: 2.5rem; margin-bottom: 10px; } .empty-text { font-size: 0.85rem; line-height: 1.5; } .section-header { display: flex; align-items: center; justify-content: space-between; padding: 4px 16px 8px; } .section-header h3 { font-family: 'Fraunces', serif; font-size: 1rem; } .section-header a { font-size: 0.78rem; color: var(--accent); text-decoration: none; } .chip-row { display: flex; gap: 8px; overflow-x: auto; padding: 0 16px 4px; scrollbar-width: none; } .chip-row::-webkit-scrollbar { display: none; } .chip { white-space: nowrap; padding: 6px 14px; border-radius: 20px; border: 1px solid var(--border); background: var(--surface); color: var(--text2); font-size: 0.8rem; cursor: pointer; transition: all var(--transition); flex-shrink: 0; } .chip.active { background: var(--accent); color: #1a1a2e; border-color: var(--accent); } .delete-btn { background: none; border: none; color: var(--danger); font-size: 0.8rem; cursor: pointer; padding: 2px 6px; opacity: 0.6; transition: opacity var(--transition); } .delete-btn:active { opacity: 1; } .api-key-wrap { position: relative; } .api-key-wrap .form-input { padding-right: 44px; } .api-key-toggle { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); background: none; border: none; color: var(--text2); cursor: pointer; font-size: 1rem; } .centenar-tracker { background: linear-gradient(135deg, rgba(124,106,247,0.2), rgba(78,205,196,0.1)); border: 1px solid rgba(124,106,247,0.3); } .centenar-progress { height: 8px; background: var(--surface3); border-radius: 4px; margin: 10px 0; overflow: hidden; } .centenar-bar { height: 100%; background: linear-gradient(to right, var(--accent2), var(--accent3)); border-radius: 4px; transition: width 0.6s ease; } .income-row { display: flex; justify-content: space-between; align-items: center; padding: 10px 12px; background: var(--surface2); border-radius: var(--radius-sm); margin-bottom: 6px; } .income-amount { font-family: 'Fraunces', serif; color: var(--success); } ::-webkit-scrollbar { width: 0; } /* ─── SYNC INDICATOR ─────────────────────────────── */ #sync-indicator { position: fixed; top: 60px; right: 16px; background: rgba(78,205,196,0.9); color: #000; padding: 6px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 500; z-index: 1000; transition: opacity 0.5s; pointer-events: none; } /* ─── TOAST ──────────────────────────────────────── */ .toast { position: fixed; bottom: 100px; left: 50%; transform: translateX(-50%); background: var(--surface2); color: var(--text); padding: 10px 20px; border-radius: 20px; font-size: 0.85rem; z-index: 400; box-shadow: var(--shadow); border: 1px solid var(--border); animation: toastIn 0.2s ease, toastOut 0.3s ease 2s forwards; white-space: nowrap; } @keyframes toastIn { from { opacity: 0; transform: translateX(-50%) translateY(10px); } to { opacity: 1; transform: translateX(-50%) none; } } @keyframes toastOut { to { opacity: 0; transform: translateX(-50%) translateY(10px); } } </style>
</head>
<body>

<!-- ═══════════════════════════════════════════════════ ONBOARDING ═══════════════════════════════════════════════════ -->
<div class="onboarding" id="onboarding">
  <div class="ob-header">
    <div class="ob-emoji">🏡</div>
    <div class="ob-title">HomeFinance Pro</div>
    <div class="ob-sub">Let's personalize your household budget tracker. Just a few questions to get started.</div>
  </div>
  <div class="ob-progress" id="ob-progress"></div>
  <div class="ob-steps">

    <!-- Step 0: Family -->
    <div class="ob-step active" data-step="0">
      <div class="ob-step-title">👨‍👩‍👧‍👦 Your Household</div>
      <div class="ob-step-sub">Who lives with you?</div>
      <div class="form-group">
        <label class="form-label">Your name</label>
        <input class="form-input" id="ob-name" placeholder="e.g. Alex" type="text" autocomplete="given-name">
      </div>
      <div class="form-group">
        <label class="form-label">Partner's name (optional)</label>
        <input class="form-input" id="ob-partner" placeholder="e.g. Jordan" autocomplete="given-name">
      </div>
      <div class="form-group">
        <label class="form-label">Other household members</label>
        <div id="ob-members-list" style="display:flex;flex-direction:column;gap:6px;margin-bottom:8px"></div>
        <div style="display:flex;gap:8px">
          <input class="form-input" id="ob-member-name" placeholder="Name" style="flex:1">
          <input class="form-input" id="ob-member-age" placeholder="Age" type="number" style="width:80px" min="0" max="120">
          <button class="btn btn-secondary" onclick="addObMember()" style="width:44px;padding:0">+</button>
        </div>
      </div>
    </div>

    <!-- Step 1: Habits -->
    <div class="ob-step" data-step="1">
      <div class="ob-step-title">🍽️ Spending Habits</div>
      <div class="ob-step-sub">This helps us give smarter suggestions.</div>
      <div class="form-group">
        <label class="form-label">What do you do at home? (select all that apply)</label>
        <div style="display:flex;flex-wrap:wrap;gap:8px;margin-top:4px" id="ob-cooking-opts">
          <span class="stock-chip" onclick="this.classList.toggle('active')" data-val="homebread">🍞 Home bread</span>
          <span class="stock-chip" onclick="this.classList.toggle('active')" data-val="cookhome">🍳 Cook at home</span>
          <span class="stock-chip" onclick="this.classList.toggle('active')" data-val="noeatout">🚫 Never eat out</span>
          <span class="stock-chip" onclick="this.classList.toggle('active')" data-val="bulkchicken">🐔 Bulk chicken</span>
          <span class="stock-chip" onclick="this.classList.toggle('active')" data-val="bulkveggies">🥕 Bulk veggies</span>
          <span class="stock-chip" onclick="this.classList.toggle('active')" data-val="mealprep">📦 Meal prep</span>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Dietary restrictions / allergies</label>
        <input class="form-input" id="ob-allergies" placeholder="e.g. gluten-free, dairy-free...">
      </div>
    </div>

    <!-- Step 2: Budget -->
    <div class="ob-step" data-step="2">
      <div class="ob-step-title">💰 Monthly Budget</div>
      <div class="ob-step-sub">Starting values — you can change these anytime.</div>
      <div class="form-group">
        <label class="form-label">Monthly income ($)</label>
        <input class="form-input" id="ob-income" type="number" value="5000" min="0">
      </div>
      <div class="form-group">
        <label class="form-label">🛒 Groceries budget ($)</label>
        <input class="form-input" id="ob-food-budget" type="number" value="800" min="0">
      </div>
      <div class="form-group">
        <label class="form-label">🚨 Emergency fund (monthly $)</label>
        <input class="form-input" id="ob-emergency" type="number" value="200" min="0">
      </div>
      <div class="form-group">
        <label class="form-label">🏥 Healthcare budget ($)</label>
        <input class="form-input" id="ob-health" type="number" value="150" min="0">
      </div>
      <div class="form-group">
        <label class="form-label">🐷 Monthly savings goal ($)</label>
        <input class="form-input" id="ob-savings" type="number" value="500" min="0">
      </div>
    </div>

    <!-- Step 3: API Key -->
    <div class="ob-step" data-step="3">
      <div class="ob-step-title">🤖 AI Features</div>
      <div class="ob-step-sub">Unlock receipt scanning and personalized budget advice. Completely optional.</div>
      <div class="form-group">
        <label class="form-label">Anthropic API Key</label>
        <div class="api-key-wrap">
          <input class="form-input" id="ob-apikey" type="password" placeholder="sk-ant-...">
          <button class="api-key-toggle" onclick="togglePassVis('ob-apikey',this)">👁</button>
        </div>
        <div style="font-size:0.72rem;color:var(--text3);margin-top:6px;line-height:1.5">
          Get your key at <strong>console.anthropic.com</strong>. Stored locally on your device only — never sent to our servers.
        </div>
      </div>
      <div style="background:var(--surface2);border-radius:var(--radius-sm);padding:14px;border-left:3px solid var(--accent2)">
        <div style="font-size:.78rem;font-weight:500;margin-bottom:6px">🔓 With AI you get:</div>
        <div style="font-size:.75rem;color:var(--text2);line-height:1.8">
          📷 Auto-scan receipts from any store<br>
          🥘 Meal suggestions based on your pantry<br>
          📊 Personalized savings recommendations<br>
          ✨ Smart budget optimization
        </div>
      </div>
    </div>

  </div>
  <div style="padding:0 20px 60px;display:flex;gap:10px" id="ob-btns">
    <button class="btn btn-secondary" id="ob-back" onclick="obPrev()" style="display:none">← Back</button>
    <button class="btn btn-primary" id="ob-next" onclick="obNext()">Continue →</button>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ SCREEN: DASHBOARD ═══════════════════════════════════════════════════ -->
<div class="screen active" id="screen-home">
  <div class="topbar">
    <div>
      <div class="topbar-title" id="greeting">HomeFinance Pro 🏡</div>
      <div class="topbar-sub" id="topbar-sub">Loading...</div>
    </div>
    <button class="icon-btn" onclick="showScreen('screen-settings')" aria-label="Settings">⚙️</button>
  </div>

  <div class="month-selector">
    <button class="month-btn" onclick="changeMonth(-1)" aria-label="Previous month">‹</button>
    <div class="month-label" id="month-label">—</div>
    <button class="month-btn" onclick="changeMonth(1)" aria-label="Next month">›</button>
  </div>

  <!-- Budget ring -->
  <div class="card">
    <div class="card-title">Monthly Budget</div>
    <div class="budget-ring">
      <div class="ring-wrap" role="img" aria-label="Budget usage ring">
        <svg width="90" height="90" viewBox="0 0 90 90">
          <circle cx="45" cy="45" r="38" fill="none" stroke="#2e2e48" stroke-width="8"/>
          <circle cx="45" cy="45" r="38" fill="none" stroke="#e8c547" stroke-width="8" stroke-dasharray="239" stroke-dashoffset="239" id="ring-progress" stroke-linecap="round"/>
        </svg>
        <div class="ring-center">
          <div class="ring-pct" id="ring-pct">0%</div>
          <div class="ring-lbl">spent</div>
        </div>
      </div>
      <div class="budget-stats">
        <div class="budget-row"><span class="label">Income</span><span class="value value-good" id="dash-income">$0</span></div>
        <div class="budget-row"><span class="label">Spent</span><span class="value" id="dash-spent">$0</span></div>
        <div class="budget-row"><span class="label">Remaining</span><span class="value" id="dash-left" style="color:var(--accent)">$0</span></div>
      </div>
    </div>
  </div>

  <!-- Payment split -->
  <div class="card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">
      <div class="card-title" style="margin-bottom:0">By Account</div>
      <div style="display:flex;gap:6px">
        <button class="pay-tab-btn active" id="tab-est" onclick="switchPayTab('est')" style="padding:4px 10px;border-radius:12px;border:1px solid var(--accent);background:var(--accent);color:#1a1a2e;font-size:.7rem;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:500">
          Estimated
        </button>
        <button class="pay-tab-btn" id="tab-real" onclick="switchPayTab('real')" style="padding:4px 10px;border-radius:12px;border:1px solid var(--border);background:none;color:var(--text2);font-size:.7rem;cursor:pointer;font-family:'DM Sans',sans-serif">
          Paid
        </button>
      </div>
    </div>
    <div class="payment-split">
      <div class="pay-chip ing"><div class="pay-label">Checking</div><div class="pay-amount" id="dash-ing">$0</div></div>
      <div class="pay-chip cash"><div class="pay-label">Cash</div><div class="pay-amount" id="dash-cash">$0</div></div>
      <div class="pay-chip rev"><div class="pay-label">Card</div><div class="pay-amount" id="dash-rev">$0</div></div>
    </div>
    <div style="display:flex;justify-content:space-between;margin-top:10px;padding-top:10px;border-top:1px solid var(--border)">
      <span style="font-size:.72rem;color:var(--text3)" id="pay-tab-label">Estimated from all fixed expenses + logged transactions</span>
    </div>
  </div>

  <!-- Savings goal card -->
  <div class="card centenar-tracker" id="savings-goal-card">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <div class="card-title" style="margin-bottom:0" id="savings-card-title">🏦 Savings Goal</div>
      <button onclick="openSavingsSettings()" style="background:none;border:none;color:var(--text2);cursor:pointer;font-size:.8rem;padding:2px 6px">⚙️</button>
    </div>
    <div style="display:flex;justify-content:space-between;align-items:baseline">
      <div style="font-family:'Fraunces',serif;font-size:1.5rem;font-weight:600" id="savings-total">$0</div>
      <div style="font-size:0.75rem;color:var(--text2)">target <span id="savings-target-lbl">$2,400</span>/yr</div>
    </div>
    <div class="centenar-progress"><div class="centenar-bar" id="savings-bar" style="width:0%"></div></div>
    <div style="display:flex;justify-content:space-between;font-size:0.75rem;color:var(--text2)">
      <span id="savings-this-year">This year: $0</span>
      <span id="savings-pct">0% of goal</span>
    </div>
  </div>

  <!-- Payment goals mini -->
  <div id="dash-pg-card" style="display:none;margin:0 16px 12px">
    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px">
      <div style="font-family:'Fraunces',serif;font-size:1rem">🎯 Upcoming Payments</div>
      <a href="#" onclick="showScreen('screen-upcoming');renderPaymentGoals();return false" style="font-size:.78rem;color:var(--accent);text-decoration:none">View all</a>
    </div>
    <div id="dash-pg-list"></div>
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0 0;border-top:1px solid var(--border);margin-top:4px">
      <span style="font-size:.75rem;color:var(--text2)">Monthly needed</span>
      <span style="font-family:'Fraunces',serif;font-size:.95rem;font-weight:600;color:var(--accent)" id="dash-pg-monthly">$0</span>
    </div>
  </div>

  <!-- Categories -->
  <div class="section-header">
    <h3>Categories</h3>
    <a href="#" onclick="showScreen('screen-expenses');return false">See all</a>
  </div>
  <div style="padding:0 16px" id="dash-categories">
    <div class="empty-state"><div class="empty-icon">📊</div><div class="empty-text">No expenses yet this month</div></div>
  </div>

  <!-- Recent -->
  <div class="section-header" style="margin-top:8px">
    <h3>Recent Transactions</h3>
    <a href="#" onclick="showScreen('screen-expenses');return false">All</a>
  </div>
  <div style="padding:0 16px 8px" id="dash-recent">
    <div class="empty-state"><div class="empty-icon">🧾</div><div class="empty-text">Tap + to add your first expense</div></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ SCREEN: EXPENSES ═══════════════════════════════════════════════════ -->
<div class="screen" id="screen-expenses">
  <div class="topbar">
    <div>
      <div class="topbar-title">Expenses</div>
      <div class="topbar-sub" id="exp-month-sub">—</div>
    </div>
    <button class="icon-btn" onclick="openAddExpense()" aria-label="Add expense">+</button>
  </div>

  <div class="month-selector">
    <button class="month-btn" onclick="changeMonth(-1)">‹</button>
    <div class="month-label" id="exp-month-label">—</div>
    <button class="month-btn" onclick="changeMonth(1)">›</button>
  </div>

  <!-- Fixed expenses -->
  <div style="display:flex;align-items:center;justify-content:space-between;padding:4px 16px 8px">
    <h3 style="font-family:'Fraunces',serif;font-size:1rem">📋 Fixed Monthly Bills</h3>
    <a href="#" onclick="openManageFixed();return false" style="font-size:.78rem;color:var(--accent);text-decoration:none">Edit list</a>
  </div>
  <div style="padding:0 16px;margin-bottom:4px;font-size:.72rem;color:var(--text3)">Tap amount to edit · Check ✓ when paid</div>
  <div style="padding:0 16px" id="fixed-list"></div>

  <!-- Variable expenses -->
  <div style="padding:8px 16px 4px"></div>
  <div style="padding:0 16px" id="exp-list">
    <div class="empty-state"><div class="empty-icon">🧾</div><div class="empty-text">No variable expenses this month</div></div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════ SCREEN: SCAN ═══════════════════════════════════════════════════ -->
<div class="screen" id="screen-scan">
  <div class="topbar">
    <div class="topbar-title">Scan Receipt 📸</div>
  </div>

  <div style="padding:0 16px 12px;font-size:0.82rem;color:var(--text2);line-height:1.5">
    Upload any receipt — photo, screenshot or PDF. AI extracts all items automatically.
  </div>

  <div class="scan-area" id="scan-area" onclick="document.getElementById('scan-file').click()" role="button" tabindex="0">
    <input type="file" id="scan-file" accept="image/*,application/pdf,.pdf" multiple onchange="handleScanFiles(event)" style="display:none">
    <div class="scan-icon">📷</div>
    <div class="scan-title">Tap to upload receipt</div>
    <div class="scan-sub">Photo, screenshot or PDF · any store</div>
  </div>

  <div id="scan-previews"></div>

  <div id="scan-loading" style="display:none">
    <div class="loading"><div class="spinner"></div> AI is analyzing your receipt...</div>
  </div>

  <div id="scan-result" style="display:none">
    <div style="padding:12px 16px 8px;font-family:'Fraunces',serif;font-size:1rem">Extracted items:</div>
    <div class="ai-result">
      <div class="ai-result-title">✨ AI Analysis</div>
      <div id="scan-items-list"></div>
      <div class="ai-total"><span>Total</span><span id="scan-total">$0</span></div>
    </div>
    <div style="padding:12px 16px">
      <div class="form-group">
        <label class="form-label">Category</label>
        <select class="form-select" id="scan-cat"></select>
      </div>
      <div class="form-group">
        <label class="form-label">Payment method</label>
        <div class="pay-selector">
          <button class="pay-opt" onclick="selectPay('scan','ing')" id="scan-pay-ing">Checking</button>
          <button class="pay-opt" onclick="selectPay('scan','cash')" id="scan-pay-cash">Cash</button>
          <button class="pay-opt" onclick="selectPay('scan','rev')" id="scan-pay-rev">Card</button>
        </div>
      </div>
      <button class="btn btn-primary" onclick="saveScanExpense()">💾 Save Expense</button>
    </div>
  </div>

  <div id="no-api-msg" style="display:none;padding:16px">
    <div class="tip-card">
      <div class="tip-badge">⚠️ API Key Required</div>
      <div class="tip-text">Add your Anthropic API Key in Settings → AI & Integrations to enable receipt scanning.</div>
